{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentrank.local/schemas/agent_card_core.schema.json",
  "title": "AgentRank core Agent Card subset (Week 2 ingest contract)",
  "description": "Aligns with A2A Agent Card required fields used by agentrank-card. Not a full A2A spec replacement.",
  "type": "object",
  "required": ["name", "description", "version", "url"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "minLength": 1, "pattern": "^https?://" }
  }
}
