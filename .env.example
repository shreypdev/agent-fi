# Copy to .env for local development (never commit .env).
# Values match apps/dev/docker-compose.yml defaults.

DATABASE_URL=postgresql://agentrank:agentrank@127.0.0.1:5433/agentrank
REDIS_URL=redis://127.0.0.1:6379

# Qdrant gRPC URL (hybrid search + vectors). Docker Compose: http://127.0.0.1:6334
# QDRANT_URL=http://127.0.0.1:6334

# Public base URL for MCP manifest + Agent Card on searchd (no trailing slash)
# AGENTRANK_PUBLIC_URL=http://127.0.0.1:8090

# Embeddings: `hash` (deterministic 768-d, default for CI) — future `bge` when ONNX wired
# AGENTRANK_EMBEDDER=hash

# Tantivy index directory (agentrank-index rebuild, searchd)
# SEARCH_INDEX_PATH=./.agentrank-search-index

# searchd HTTP port (Railway sets PORT automatically)
# PORT=8080

# Optional: comma-separated origins; empty = allow any origin (demo-friendly).
# Production: set explicit origins (landing + preview URLs) and enable strict mode:
# CORS_ORIGINS=https://your-landing.up.railway.app
# CORS_REQUIRE_ORIGINS=1

# Rate-limit client IP: on Railway, X-Forwarded-For is trusted automatically if unset.
# Use TRUST_PROXY_HEADERS=0 to force TCP peer only (e.g. debugging). Use =1 to force trust off-Railway.
# TRUST_PROXY_HEADERS=0

# Protect GET /metrics in prod (scrape with Authorization: Bearer <token>).
# METRICS_BEARER_TOKEN=

# Index boot: full = rebuild every start; reuse = skip rebuild if probe succeeds (use with persistent volume).
# SEARCHD_INDEX_BOOT=reuse

# Anonymous searches per client IP per minute (Redis fixed window)
# SEARCH_RATE_LIMIT_PER_MINUTE=120

# Landing: searchd base URL (no trailing slash), baked in at build time. Use http:// or https://
# for local dev; host-only values (e.g. api.up.railway.app) are normalized to https:// in the app.
# VITE_SEARCH_API_BASE_URL=http://127.0.0.1:8090

# Optional: RUST_LOG=debug for healthd / future Rust binaries
# RUST_LOG=info

# --- AgentRank Docker (Railway): AGENTRANK_PROCESS=searchd | consoled | agentbot ---
# AGENTRANK_PROCESS=searchd

# --- AgentBot (crawl / discover) ---
# AGENTBOT_DISCOVER_INTERVAL_SECS=3600   # scheduled discover (builtin + HTTP JSON feeds + optional registry feeds)
# AGENTBOT_DISCOVER_HTTP_JSONS=https://example.com/api/agent-urls.json
# PULSEMCP_FEED_URL=   # optional JSON URL list (same format as http_json_urls)
# MCPSO_FEED_URL=
# AGENTBOT_BOOT_DISCOVER=1   # Docker/Railway: run `discover builtin` once before run-loop
# AGENTBOT_METRICS_BIND=127.0.0.1:9092
# AGENTBOT_ALLOW_HTTP_LOCALHOST=1
# GITHUB_TOKEN=ghp_...   # discover github
# GITHUB_API_BASE_URL=https://api.github.com   # override for tests / mocks

# --- Console API (agentrank-consoled) ---
# PORT=8091
# CONSOLE_API_KEY=change-me
# CONSOLE_CORS_ORIGIN=http://127.0.0.1:5174

# Console UI build (apps/console)
# VITE_CONSOLE_API_BASE=http://127.0.0.1:8091
